# ===== LINE（必須）=====
# https://developers.line.biz/console/ で取得
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
LINE_CHANNEL_SECRET=your_channel_secret

# グループID（BOTをグループに入れて、一度メッセージを送るとログに出ます）
# 例: Cxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_GROUP_ID=

# ===== AI（任意・後からでOK）=====
# https://console.x.ai で取得。未設定でも日付送信は動く
XAI_API_KEY=
XAI_MODEL=grok-4.5

# ===== 運用 =====
# Cronから叩くときの合言葉（自分で決める適当な文字列）
# クラウドでは cron-job.org の URL にも同じ値を入れる
CRON_SECRET=change-me-to-random-string

# タイムゾーン（Render でも推奨）
TZ=Asia/Tokyo

# ポート（ローカル用。クラウドは自動で PORT が入る）
PORT=8000

# データ保存先（通常は不要。Render Disk を使うときだけ）
# DATA_DIR=/var/data

